// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  price       Float
  author      String
  cover       String
  description String
  createdAt   DateTime @default(now())

  /**
   * Relationship fields to Category
   */
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
}
